# Ignore build artifacts and executables
/build/
/bin/
/*.exe
/*.out

# Ignore object files and libraries
*.o
*.a

# Ignore generated files and directories
CMakeFiles/
CMakeCache.txt
compile_commands.json
Makefile
.vscode/
.idea/

# Ignore system and editor-specific files
*.swp
*.swo
.DS_Store

# Ignore user-specific settings files
CMakeUserPresets.json

# Ignore temporary files
*.log
*.tmp
*.bak
*.zip
*.tar.gz

# Ignore Visual Studio files
*.sln
*.vcxproj
*.vcxproj.filters
*.vcxproj.user
*.pdb
*.idb

# Ignore clangd-related files
.compile_commands.json
compile_commands.json